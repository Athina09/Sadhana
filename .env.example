# Supabase setup
# 1) Create project on https://supabase.com
# 2) Project Settings -> API
# 3) Copy values into .env (same directory as package.json)
# 4) Run SQL from supabase/migrations/001_sessions.sql in Supabase SQL Editor
# 5) Restart dev server

VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# 1) supabase.com → New project
# 2) Project Settings → API → copy URL + anon public key into .env (same folder as package.json)
# 3) SQL Editor → paste full file supabase/migrations/001_sessions.sql → Run
# 4) Authentication → Providers → Email ON (disable "Confirm email" for quick testing if you want)
# 5) Restart: npm run dev

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
